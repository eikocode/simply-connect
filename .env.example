# Simply-Connect Environment Variables
# Copy to .env and fill in your values.

# ── Anthropic API key ─────────────────────────────────────────
# Required for SDK runtime and Claude vision document parsing.
# Optional if using Claude Code OAuth — omit this line and the
# system falls back to `claude --print` subprocess automatically.
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Telegram Relay (sc-relay) ─────────────────────────────────
# Bot token from @BotFather
SC_TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Comma-separated Telegram user IDs allowed to use the bot.
# Leave empty to allow all users (not recommended for production).
SC_TELEGRAM_ALLOWED_USERS=

# ── Runtime selection ─────────────────────────────────────────
# "sdk"            — in-process, calls brain.respond() directly
# "cli"/"claude"   — Claude CLI subprocess, MCP server handles tools
# "opencode"       — OpenCode CLI subprocess, MCP server handles tools
# "kilo"           — Kilo CLI subprocess, MCP server handles tools
SC_CLAUDE_RUNTIME=opencode

# ── Document parser ───────────────────────────────────────────
# "claude"  (default) — Claude vision API; requires ANTHROPIC_API_KEY
# "docling"           — local Docling parser; no API key needed
#                       Install: pip install -e ".[docling]"
SC_DOCUMENT_PARSER=claude

# ── MCP Server (sc-mcp) ───────────────────────────────────────
# HTTP port for the MCP server when running --http mode
# Default: 3004
SC_MCP_PORT=3004

# ── Domains library ───────────────────────────────────────────
# Path to the simply-connect-domains/domains folder.
# Auto-detected if simply-connect-domains/ is cloned next to simply-connect/.
# SC_DOMAINS_DIR=/path/to/simply-connect-domains/domains

# ── Data directory override ───────────────────────────────────
# Override the default data/ directory for sessions and staging.
# Default: auto-detected from project root.
# SC_DATA_DIR=/path/to/data

# ── Multi-role Telegram bots ──────────────────────────────────
# When profile.json declares roles with telegram_bot_env, set each here.
# The env var name matches what's in profile.json → roles → <role> → telegram_bot_env.
# Example for a domain with lawyer and client roles:
# SC_LAWYER_BOT_TOKEN=your_lawyer_bot_token_here
# SC_CLIENT_BOT_TOKEN=your_client_bot_token_here
# Then run: sc-relay --role lawyer   and   sc-relay --role client

# ── Extensions: Minpaku ───────────────────────────────────────
# Required when the minpaku extension is active in profile.json.
# MINPAKU_API_URL=http://164.90.151.217:8000
# MINPAKU_API_KEY=your_minpaku_api_key_here
